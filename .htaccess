# ============================================================
#  Vivant Osteo & Physio — Apache config (shared hosting / cPanel)
#  If your host is NOT Apache (Netlify, Vercel, nginx), this file
#  is ignored — configure the equivalents in that host's panel.
# ============================================================

# ── Custom 404 page ──
ErrorDocument 404 /404.html

# ── Force HTTPS + canonical www (matches canonical https://www.vivantop.ro) ──
<IfModule mod_rewrite.c>
  RewriteEngine On

  # http -> https
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://www.vivantop.ro/$1 [R=301,L]

  # non-www -> www
  RewriteCond %{HTTP_HOST} ^vivantop\.ro$ [NC]
  RewriteRule ^(.*)$ https://www.vivantop.ro/$1 [R=301,L]
</IfModule>

# ── GZIP compression ──
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml text/xml application/xml
</IfModule>

# ── Browser caching ──
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css                "access plus 1 year"
  ExpiresByType application/javascript  "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 year"
  ExpiresByType image/x-icon            "access plus 1 year"
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType text/html               "access plus 0 seconds"
  ExpiresByType application/xml         "access plus 1 day"
</IfModule>

# ── Security / SEO headers ──
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
</IfModule>
